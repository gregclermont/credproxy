#!/bin/sh
# credproxy bundled provider: env
#
# Reads host environment variables named by the request's `secrets` refs and
# returns their values. Implements the batch provider protocol (docs/providers.md).
#
#   Request  (stdin):  {"version":1,"op":"get","secrets":["GITHUB_TOKEN", ...]}
#   Response (stdout): {"values":{"GITHUB_TOKEN":"<value>", ...}}
#   Exit 2 if any variable is unset; exit 3 on an unsupported version/op.
#
# Uses python3 -c for JSON parsing -- the proxy host needs python3 anyway, so
# this keeps the script dependency-free and quoting-safe. The request JSON
# arrives on stdin (note: a `<<HEREDOC` would consume stdin, so we use -c).
# Copy this file as a starting point (`credproxy provider scaffold NAME`).
exec python3 -c '
import json, os, sys
try:
    req = json.load(sys.stdin)
except Exception as e:
    print(f"env provider: bad request JSON: {e}", file=sys.stderr)
    sys.exit(1)
if req.get("version") != 1 or req.get("op") != "get":
    print("env provider: unsupported version/op", file=sys.stderr)
    sys.exit(3)
refs = req.get("secrets") or []
values = {}
for name in refs:
    val = os.environ.get(name)
    if val is None:
        print(f"env provider: ${name} is not set in the host environment",
              file=sys.stderr)
        sys.exit(2)
    values[name] = val
json.dump({"values": values}, sys.stdout)
'
