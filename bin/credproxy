#!/usr/bin/env python3
"""credproxy: the strict, scriptable workspace manager for the credproxy
egress proxy.

Thin shim: locate the repo-relative package and hand off to its porcelain
main() with the strict (default) surface. The human alias `credp` is a sibling
shim that flips on the convenience surface; see bin/credp and design-v2.md for
the substrate/wrapper split.
"""
import sys
from pathlib import Path

# This shim lives at <repo>/bin/credproxy; the package is at <repo>/cli.
sys.path.insert(0, str(Path(__file__).resolve().parent.parent / "cli"))

from credproxy_cli.porcelain.cli import main

if __name__ == "__main__":
    main(loose_default=False)
