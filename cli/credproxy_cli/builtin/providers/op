#!/usr/bin/env python3
# credproxy provider: op (1Password)  —  protocol: docs/providers.md
#
# A provider is a standalone executable speaking the batch protocol. Everything
# specific to THIS provider is the metadata block and the get() function; the
# protocol footer is identical across providers. Copy this file as a starting
# point with `credproxy provider scaffold NAME`.
import json
import subprocess
import sys

# ════ metadata ═══════════════════════════════════════════════════════
NAME = "op"
DESCRIPTION = "1Password (op CLI)"
PROTOCOL_VERSION = 1
HELP = """\
Reads secrets from 1Password (op CLI).
  ref:     a secret reference, op://<vault>/<item>/<field>
  example: --provider op --secret "op://Private/Anthropic/credential"
Requires `op` authenticated (op signin, or the desktop-app integration).
"""

# ════ fetch one secret (the only provider-specific logic) ═════════════
class NotFound(Exception):
    """A ref that doesn't resolve -> exit 2."""


class Missing(Exception):
    """The backend CLI is not installed -> exit 1 (a clean error, not a traceback)."""


def get(ref):
    try:
        r = subprocess.run(["op", "read", ref], capture_output=True, text=True)
    except FileNotFoundError:
        raise Missing("`op` is not on PATH (install the 1Password CLI)")
    if r.returncode != 0:
        raise NotFound(f"could not read {ref!r}: {r.stderr.strip()}")
    # `op read` appends a single trailing newline; strip just that one (a field
    # could legitimately end in \n, e.g. a multi-line key).
    return r.stdout.removesuffix("\n")


# ════ protocol footer (identical for every provider — skip on a scan) ═
def _fail(msg, code):
    print(f"{NAME} provider: {msg}", file=sys.stderr)
    sys.exit(code)


def main():
    try:
        req = json.load(sys.stdin)
    except Exception as e:
        _fail(f"bad request JSON: {e}", 1)
    if req.get("version") != PROTOCOL_VERSION:
        _fail("unsupported version", 3)
    op = req.get("op")
    if op == "describe":
        json.dump({"description": DESCRIPTION}, sys.stdout)
    elif op == "help":
        json.dump({"help": HELP}, sys.stdout)
    elif op == "get":
        values = {}
        try:
            for ref in req.get("secrets") or []:
                values[ref] = get(ref)
        except NotFound as e:
            _fail(str(e), 2)
        except Missing as e:
            _fail(str(e), 1)
        json.dump({"values": values}, sys.stdout)
    else:
        _fail("unsupported op", 3)


main()
