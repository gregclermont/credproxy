#!/usr/bin/env python3
# credproxy provider: docker-credential (Docker credential helpers)
#   protocol: docs/providers.md
#
# A provider is a standalone executable speaking the batch protocol. Everything
# specific to THIS provider is the metadata block and the get() function; the
# protocol footer is identical across providers. Copy this file as a starting
# point with `credproxy provider scaffold NAME`.
#
# Adapts ANY `docker-credential-*` helper: it runs the helper's `get` for a
# registry host and returns the Secret. The helper protocol is per-host (no
# batch get), so a batch still invokes the helper once per distinct (helper,
# host) pair -- but the docker config is read once per invocation, and the CLI's
# cross-binding batching pays the process-startup cost once per resolve.
import json
import os
import subprocess
import sys
from pathlib import Path

# ════ metadata ═══════════════════════════════════════════════════════
NAME = "docker-credential"
DESCRIPTION = "Docker credential helper (registry auth)"
PROTOCOL_VERSION = 1
HELP = """\
Fetches a registry credential through a Docker credential helper
(docker-credential-*), reusing what Docker is already configured to use.
  ref:     <host>  or  <helper>|<host>
           <host>          -- a registry host; the helper is resolved from
                              ${DOCKER_CONFIG:-~/.docker}/config.json
                              (credHelpers[host], else credsStore).
           <helper>|<host> -- name the helper's suffix explicitly (e.g.
                              ecr-login, osxkeychain, pass, gcloud).
  example: --provider docker-credential --secret ghcr.io
           --provider docker-credential --secret "ecr-login|123.dkr.ecr.us-east-1.amazonaws.com"
Returns the helper's Secret (the password). Pairs with the `basic` scheme, which
swaps the password component by position -- so the USERNAME is NOT injected; the
workspace must send the username the registry expects (e.g. `AWS` for ECR) with
the placeholder in the password slot. Covers only the credential-HELPER
mechanism (credHelpers/credsStore), not the static base64 `auths` a plain
`docker login` may write. describe/help never read the config or run a helper,
so listing providers is side-effect free. Requires the relevant
`docker-credential-*` on PATH (and, for a bare-host ref, a credHelpers/credsStore
entry to name it).
"""


# ════ fetch one secret (the only provider-specific logic) ═════════════
class NotFound(Exception):
    """A ref with no helper / no stored credential -> exit 2."""


class DockerCredError(Exception):
    """A backend failure (helper missing, unreadable/garbled config) -> exit 1."""


# Cached for the lifetime of one invocation: the parsed docker config (or {} if
# absent), so a batch of bare-host refs reads config.json at most once; and the
# per-(helper, host) results, so the same credential is fetched once even if two
# bindings spell its ref differently (`ghcr.io` vs `osxkeychain|ghcr.io`).
_CONFIG = None
_RESULTS: dict[tuple[str, str], str] = {}


def _config():
    global _CONFIG
    if _CONFIG is not None:
        return _CONFIG
    base = os.environ.get("DOCKER_CONFIG") or os.path.expanduser("~/.docker")
    path = Path(base) / "config.json"
    try:
        _CONFIG = json.loads(path.read_text())
    except FileNotFoundError:
        _CONFIG = {}
    except (ValueError, OSError) as e:
        raise DockerCredError(f"could not read {path}: {e}")
    if not isinstance(_CONFIG, dict):
        raise DockerCredError(f"{path} is not a JSON object")
    return _CONFIG


def _resolve_helper(host):
    """The helper suffix for a bare host: credHelpers[host], else credsStore."""
    cfg = _config()
    helpers = cfg.get("credHelpers") or {}
    helper = helpers.get(host) or cfg.get("credsStore")
    if not helper:
        raise NotFound(
            f"no Docker credential helper for {host!r} (no credHelpers entry and "
            f"no credsStore; name one as `<helper>|{host}`)"
        )
    return helper


def get(ref):
    helper_ref, sep, host = ref.partition("|")
    if not sep:
        host = ref
        helper = _resolve_helper(host)
    else:
        helper = helper_ref
    if not host:
        raise NotFound(f"empty registry host in ref {ref!r}")
    if not helper:
        raise NotFound(f"empty helper in ref {ref!r}")

    key = (helper, host)
    if key in _RESULTS:
        return _RESULTS[key]

    exe = f"docker-credential-{helper}"
    try:
        r = subprocess.run([exe, "get"], input=host, capture_output=True, text=True)
    except FileNotFoundError:
        raise DockerCredError(f"{exe} is not on PATH")
    if r.returncode != 0:
        raise NotFound(
            f"{exe} has no credentials for {host} "
            f"({r.stderr.strip() or 'helper exited nonzero'})"
        )
    try:
        data = json.loads(r.stdout)
    except ValueError:
        raise DockerCredError(f"{exe} returned non-JSON on stdout")
    secret = data.get("Secret") if isinstance(data, dict) else None
    if not isinstance(secret, str) or not secret:
        raise NotFound(f"{exe} returned no Secret for {host}")
    _RESULTS[key] = secret
    return secret


# ════ protocol footer (identical for every provider — skip on a scan) ═
def _fail(msg, code):
    print(f"{NAME} provider: {msg}", file=sys.stderr)
    sys.exit(code)


def main():
    try:
        req = json.load(sys.stdin)
    except Exception as e:
        _fail(f"bad request JSON: {e}", 1)
    if req.get("version") != PROTOCOL_VERSION:
        _fail("unsupported version", 3)
    op = req.get("op")
    if op == "describe":
        json.dump({"description": DESCRIPTION}, sys.stdout)
    elif op == "help":
        json.dump({"help": HELP}, sys.stdout)
    elif op == "get":
        values = {}
        try:
            for ref in req.get("secrets") or []:
                values[ref] = get(ref)
        except NotFound as e:
            _fail(str(e), 2)
        except DockerCredError as e:
            _fail(str(e), 1)
        json.dump({"values": values}, sys.stdout)
    else:
        _fail("unsupported op", 3)


main()
