#!/usr/bin/env python3
# credproxy provider: keychain  —  protocol: docs/providers.md
#
# A provider is a standalone executable speaking the batch protocol. Everything
# specific to THIS provider is the metadata block and the get() function; the
# protocol footer is identical across providers. Copy this file as a starting
# point with `credproxy provider scaffold NAME`.
import json
import subprocess
import sys

# ════ metadata ═══════════════════════════════════════════════════════
NAME = "keychain"
DESCRIPTION = "macOS Keychain (security CLI)"
PROTOCOL_VERSION = 1
HELP = """\
Fetches generic-password items from the macOS Keychain (security CLI).
  ref:     the item's SERVICE NAME
  store:   security add-generic-password -s <ref> -a "$USER" -w
  example: --provider keychain --secret anthropic-key
First access prompts; choose "Always Allow" for unattended use. macOS only.
"""

# ════ fetch one secret (the only provider-specific logic) ═════════════
class NotFound(Exception):
    """A ref that doesn't resolve -> exit 2."""


class Missing(Exception):
    """The backend CLI is not installed -> exit 1 (a clean error, not a traceback)."""


def get(ref):
    try:
        r = subprocess.run(
            ["security", "find-generic-password", "-s", ref, "-w"],
            capture_output=True, text=True,
        )
    except FileNotFoundError:
        raise Missing("`security` is not on PATH (this provider is macOS-only)")
    if r.returncode != 0:
        raise NotFound(
            f"no generic-password item with service {ref!r} "
            f'(store it: security add-generic-password -s {ref} -a "$USER" -w)'
        )
    # `-w` prints the password with a single trailing newline; strip just that
    # one, never more (a secret could legitimately end in \n).
    return r.stdout.removesuffix("\n")


# ════ protocol footer (identical for every provider — skip on a scan) ═
def _fail(msg, code):
    print(f"{NAME} provider: {msg}", file=sys.stderr)
    sys.exit(code)


def main():
    try:
        req = json.load(sys.stdin)
    except Exception as e:
        _fail(f"bad request JSON: {e}", 1)
    if req.get("version") != PROTOCOL_VERSION:
        _fail("unsupported version", 3)
    op = req.get("op")
    if op == "describe":
        json.dump({"description": DESCRIPTION}, sys.stdout)
    elif op == "help":
        json.dump({"help": HELP}, sys.stdout)
    elif op == "get":
        values = {}
        try:
            for ref in req.get("secrets") or []:
                values[ref] = get(ref)
        except NotFound as e:
            _fail(str(e), 2)
        except Missing as e:
            _fail(str(e), 1)
        json.dump({"values": values}, sys.stdout)
    else:
        _fail("unsupported op", 3)


main()
