#!/bin/sh
# credproxy bundled provider: env
#
# Reads a host environment variable named by the request's `secret` ref and
# returns its value. Implements the provider exec protocol (docs/providers.md).
#
#   Request  (stdin):  {"version":1,"op":"get","secret":"GITHUB_TOKEN"}
#   Response (stdout): {"value":"<value of $GITHUB_TOKEN>"}
#   Exit 2 if the variable is unset; exit 3 on an unsupported version/op.
#
# Uses python3 -c for JSON parsing -- the proxy host needs python3 anyway, so
# this keeps the script dependency-free and quoting-safe. The request JSON
# arrives on stdin (note: a `<<HEREDOC` would consume stdin, so we use -c).
# Copy this file as a starting point (`credproxy scaffold provider NAME`).
exec python3 -c '
import json, os, sys
try:
    req = json.load(sys.stdin)
except Exception as e:
    print(f"env provider: bad request JSON: {e}", file=sys.stderr)
    sys.exit(1)
if req.get("version") != 1 or req.get("op") != "get":
    print("env provider: unsupported version/op", file=sys.stderr)
    sys.exit(3)
name = req.get("secret") or ""
val = os.environ.get(name)
if val is None:
    print(f"env provider: ${name} is not set in the host environment",
          file=sys.stderr)
    sys.exit(2)
json.dump({"value": val}, sys.stdout)
'
